# V-11: short-lived OAuth handling for the isolated agent + defensive
# entrypoint that refuses to operate outside its expected $HOME.
# Files: nodes/nexus_agent_isolated/docker_runner.py,
#        nodes/nexus_agent_isolated/entrypoint.sh
#
# Two changes:
#  - After each container exits, the host strips the cached credentials
#    from the named volume so the long-lived OAuth token never persists
#    at rest in /var/lib/docker/volumes/.
#  - entrypoint.sh refuses to rm -rf its $HOME unless $HOME is exactly
#    /home/node — defends against a misconfigured `docker run --user`
#    that would otherwise nuke an unrelated directory.
#
# DO NOT APPLY — proposal for review.

--- a/nodes/nexus_agent_isolated/docker_runner.py
+++ b/nodes/nexus_agent_isolated/docker_runner.py
@@ -45,12 +45,29 @@ KEYCHAIN_SERVICE = "Claude Code-credentials"
 KEYCHAIN_ACCOUNT = "anthropic"


-def get_oauth_token_from_keychain() -> str | None:
-    """Reads the long-lived OAuth token from the macOS keychain."""
+def get_oauth_token_from_keychain() -> str | None:
+    """Reads the long-lived OAuth token from the macOS keychain.
+    Callers should treat the returned value as one-shot — feed it to a
+    container, then immediately overwrite their local reference."""
     try:
         out = subprocess.check_output([
             "security", "find-generic-password",
             "-s", KEYCHAIN_SERVICE, "-a", KEYCHAIN_ACCOUNT, "-w",
         ]).strip().decode()
         return out or None
     except subprocess.CalledProcessError:
         return None
+
+
+_VOLUME_NAME = "nexus_agent_isolated_ledger"
+_CREDENTIAL_PATHS_IN_VOLUME = (
+    ".claude/auth.json",
+    ".claude/credentials.json",
+    ".claude/sessions",
+)
+
+
+def _strip_volume_credentials() -> None:
+    """Run a tiny helper container that deletes credential caches from
+    the named volume. Called after every agent run so the OAuth token
+    never persists at rest in the docker volume."""
+    rm_paths = " ".join(f"/v/{p}" for p in _CREDENTIAL_PATHS_IN_VOLUME)
+    subprocess.run([
+        "docker", "run", "--rm",
+        "-v", f"{_VOLUME_NAME}:/v",
+        "alpine:3.20",
+        "sh", "-c", f"rm -rf {rm_paths} || true",
+    ], check=False)
@@ -180,12 +197,17 @@ def run_claude_in_container(prompt: str, ...) -> ClaudeResult:
-    proc = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
+    try:
+        proc = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
+    finally:
+        # Always strip credentials from the volume, even on failure.
+        _strip_volume_credentials()
     return ClaudeResult(...)
@@ -150,6 +172,8 @@ def _build_redacted_log(cmd: list[str]) -> str:
-    sensitive = ("CLAUDE_CODE_OAUTH_TOKEN=", "ANTHROPIC_API_KEY=")
+    sensitive = ("CLAUDE_CODE_OAUTH_TOKEN=", "ANTHROPIC_API_KEY=",
+                 "NEXUS_AGENT_CONTROL_TOKEN=", "OPENAI_API_KEY=")
     ...

--- a/nodes/nexus_agent_isolated/entrypoint.sh
+++ b/nodes/nexus_agent_isolated/entrypoint.sh
@@ -1,18 +1,28 @@
 #!/bin/bash
 set -euo pipefail

+# Defensive: refuse to operate from any HOME except the expected one.
+# A misconfigured `docker run --user` or `-e HOME=...` would otherwise
+# direct the rm -rf below at an arbitrary path inside the container.
+EXPECTED_HOME="/home/node"
+if [[ "${HOME:-}" != "$EXPECTED_HOME" ]]; then
+    echo "entrypoint.sh: refusing to start; HOME='${HOME:-}' (expected '$EXPECTED_HOME')" >&2
+    exit 2
+fi
+
 HOME_CLAUDE="$HOME/.claude"
 LEDGER_CLAUDE="/agent/ledger/.claude"

 mkdir -p "$LEDGER_CLAUDE"
-rm -rf "$HOME_CLAUDE"
+# Refuse to remove anything that is not our own ~/.claude link target.
+if [[ -e "$HOME_CLAUDE" && ! -L "$HOME_CLAUDE" ]]; then
+    rm -rf "$HOME_CLAUDE"
+elif [[ -L "$HOME_CLAUDE" ]]; then
+    rm -f "$HOME_CLAUDE"
+fi
 ln -s "$LEDGER_CLAUDE" "$HOME_CLAUDE"

 exec "$@"
