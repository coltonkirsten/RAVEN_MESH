# V-08: replace the publicly-known _derive recipe with a per-machine
# random master; refuse to silently fabricate secrets when env:VAR is
# missing.
# Files: scripts/_env.sh, core/core.py
#
# After this patch, every developer's mesh has unique node secrets that
# cannot be reconstructed from source-code knowledge alone. A user who
# clones the repo and forgets to export an env var gets a *startup
# failure*, not a known-weak secret.
#
# DO NOT APPLY — proposal for review.

--- a/scripts/_env.sh
+++ b/scripts/_env.sh
@@ -1,12 +1,38 @@
 #!/bin/bash
 # Sourced by all run_*.sh scripts.

-_derive() {
-    printf "mesh:%s:dev" "$1" | shasum -a 256 | cut -d' ' -f1
+# Per-machine random master, created on first run with mode 0600.
+# HMAC the node id against the master to derive a unique per-node secret
+# that is NOT recoverable from the public source code.
+_master_path() {
+    printf "%s/raven_mesh/secret_master" "${XDG_CONFIG_HOME:-$HOME/.config}"
+}
+
+_ensure_master() {
+    local p
+    p="$(_master_path)"
+    if [[ ! -f "$p" ]]; then
+        mkdir -p "$(dirname "$p")"
+        # 32 bytes of urandom, hex-encoded.
+        if command -v openssl >/dev/null 2>&1; then
+            openssl rand -hex 32 > "$p"
+        else
+            head -c 32 /dev/urandom | xxd -p -c 64 > "$p"
+        fi
+        chmod 600 "$p"
+    fi
+}
+
+_derive() {
+    _ensure_master
+    local master node
+    master="$(cat "$(_master_path)")"
+    node="$1"
+    # HMAC-SHA256(master, node_id), hex.
+    printf "%s" "$node" \
+        | openssl dgst -sha256 -hmac "$master" -hex \
+        | awk '{print $NF}'
 }

