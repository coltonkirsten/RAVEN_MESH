-        return derived
-    return spec
+    if spec.startswith("env:"):
+        var = spec[4:]
+        val = os.environ.get(var)
+        if not val:
+            # Loud failure beats silent fallback to a known-weak secret.
+            # (V-08: the prior fallback let an attacker who guessed the
