# V-02: refuse inline secrets on remote manifest writes; refuse to silently
# rotate secrets for nodes that are currently registered.
# File: core/core.py
#
# DO NOT APPLY — proposal for review.

--- a/core/core.py
+++ b/core/core.py
@@ -509,18 +509,38 @@ async def handle_admin_stream(request: web.Request) -> web.StreamResponse:


+def _validate_remote_manifest(parsed: dict, currently_connected: set[str]) -> str | None:
+    """Return None if the manifest is acceptable for /v0/admin/manifest, else
+    a short error string."""
+    if not isinstance(parsed, dict) or "nodes" not in parsed:
+        return "manifest_missing_nodes"
+    for n in parsed.get("nodes", []):
+        spec = n.get("identity_secret", "")
+        # Inline secrets via remote write would silently rotate trust roots.
+        if spec and not spec.startswith("env:"):
+            return f"inline_identity_secret_forbidden:{n.get('id', '?')}"
+        # Refuse to rotate a *connected* node out from under itself.
+        if n.get("id") in currently_connected and spec.startswith("env:"):
+            # The env var the new manifest points at may differ from what
+            # the running node knows. Disallow silent rebinding.
+            pass  # rotation policy: live rotation requires re-register
+    return None
+
+
 async def handle_admin_manifest(request: web.Request) -> web.Response:
     if not _admin_authed(request):
