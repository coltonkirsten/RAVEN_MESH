+    # If a connected node's secret env-var resolved to something different than
+    # the live secret, force a disconnect so the node must re-register and
+    # prove ownership of the new secret. (No silent take-over.)
+    for nid, decl in list(state.nodes_decl.items()):
+        conn = state.connections.get(nid)
