# V-01: lock down the admin token + the supervisor inline-runner foot-gun
# Files: core/core.py, core/supervisor.py, dashboard/vite.config.ts
#
# - Refuse to start Core without a non-default ADMIN_TOKEN.
# - Drop query-string token auth (V-18 fix folded in).
# - Drop the Access-Control-Allow-Origin: * for /v0/admin/*; honour an
#   ADMIN_ALLOWED_ORIGINS env list and require Origin to match (or be empty
#   for curl).
# - Make manifest.metadata.runner.cmd ignored unless MESH_ALLOW_INLINE_RUNNERS=1.
# - Refuse Vite dev proxy startup when ADMIN_TOKEN is unset / default.
#
# DO NOT APPLY — proposal for review.

--- a/core/core.py
+++ b/core/core.py
@@ -38,7 +38,6 @@ from core.supervisor import Supervisor, make_script_resolver


 ENVELOPE_TAIL_MAX = 200
-DEFAULT_ADMIN_TOKEN = "admin-dev-token"


 # ---------- helpers ----------
@@ -64,12 +63,30 @@ def verify(obj: dict, secret: str) -> bool:


 def admin_token() -> str:
-    return os.environ.get("ADMIN_TOKEN", DEFAULT_ADMIN_TOKEN)
+    tok = os.environ.get("ADMIN_TOKEN", "")
+    if not tok or tok == "admin-dev-token":
+        raise RuntimeError(
+            "ADMIN_TOKEN env var must be set to a non-default value before Core starts. "
+            "Generate one with: python3 -c 'import secrets; print(secrets.token_urlsafe(32))'"
+        )
+    return tok
+
+
+def _allowed_admin_origins() -> set[str]:
+    raw = os.environ.get("ADMIN_ALLOWED_ORIGINS", "")
+    return {o.strip() for o in raw.split(",") if o.strip()}


 def _admin_authed(request: web.Request) -> bool:
-    token = request.headers.get("X-Admin-Token") or request.query.get("admin_token")
-    return token == admin_token()
+    # Header only — query-string secrets land in shell history, browser history,
+    # access logs, and Referer headers. (V-18.)
+    token = request.headers.get("X-Admin-Token")
+    if not token or token != admin_token():
+        return False
+    origin = request.headers.get("Origin")
+    if origin and origin not in _allowed_admin_origins():
+        return False
+    return True


 # ---------- state ----------
@@ -710,9 +727,12 @@ async def _cors_middleware(request: web.Request, handler):
         })
     response = await handler(request)
     if request.path.startswith("/v0/admin"):
-        response.headers.setdefault("Access-Control-Allow-Origin", "*")
-        response.headers.setdefault("Access-Control-Allow-Headers", "Content-Type, X-Admin-Token")
+        origin = request.headers.get("Origin")
+        if origin and origin in _allowed_admin_origins():
+            response.headers.setdefault("Access-Control-Allow-Origin", origin)
+            response.headers.setdefault("Vary", "Origin")
+            response.headers.setdefault("Access-Control-Allow-Headers", "Content-Type, X-Admin-Token")
     return response


 # ---------- bootstrap ----------
@@ -728,6 +748,8 @@ def make_app(
 ) -> web.Application:
     audit_path = audit_path or os.environ.get("AUDIT_LOG", "audit.log")
+    # Force-evaluate so we fail at boot, not on first admin request.
+    _ = admin_token()
     app = web.Application(client_max_size=10 * 1024 * 1024, middlewares=[_cors_middleware])
     state = CoreState(manifest_path, audit_path)

--- a/core/supervisor.py
