@@ -445,12 +445,15 @@ def make_script_resolver(repo_root: str, log_dir: str) -> RunnerResolver:
     def resolve(node_id: str, manifest_node: dict) -> Optional[ChildSpec]:
         meta = manifest_node.get("metadata", {}) if manifest_node else {}
         runner_meta = meta.get("runner", {}) if isinstance(meta, dict) else {}
-        if "cmd" in runner_meta:
+        # Inline runner.cmd is RCE on a manifest write. Default off; opt in
+        # only for trusted local-only deployments.
+        allow_inline = os.environ.get("MESH_ALLOW_INLINE_RUNNERS") == "1"
+        if "cmd" in runner_meta and allow_inline:
             cmd = runner_meta["cmd"]
             if isinstance(cmd, str):
                 cmd = ["/bin/sh", "-c", cmd]
         else:
+            if "cmd" in runner_meta and not allow_inline:
+                log.warning("ignoring metadata.runner.cmd for %s "
+                            "(set MESH_ALLOW_INLINE_RUNNERS=1 to enable)", node_id)
             script = root / "scripts" / f"run_{node_id}.sh"
             if not script.exists():
                 return None
             cmd = ["/bin/bash", str(script)]

