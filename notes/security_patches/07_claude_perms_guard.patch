+"""Regression guard: the dangerous claude flag set is part of the
+security boundary. Any silent change here demands a security review."""
+
+import os
+import pytest
+
+from nexus_agent.cli_runner import (
+    CLAUDE_DANGEROUS_FLAGS,
+    _danger_flags,
+    _build_args,
+)
+
+
+def test_dangerous_flags_pinned():
+    assert CLAUDE_DANGEROUS_FLAGS == (
+        "--dangerously-skip-permissions",
+        "--strict-mcp-config",
+        "--tools", "",
+    )
+
+
+def test_default_path_does_not_skip_permissions(monkeypatch):
+    monkeypatch.delenv("MESH_ALLOW_DANGEROUS", raising=False)
+    flags = _danger_flags()
+    assert "--dangerously-skip-permissions" not in flags
+    monkeypatch.setenv("MESH_ALLOW_DANGEROUS", "1")
+    assert "--dangerously-skip-permissions" in _danger_flags()
