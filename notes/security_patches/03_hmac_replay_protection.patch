+        # Per-node replay-id LRU for invocations + responses.
+        self._seen_ids: dict[str, collections.OrderedDict] = {}
+        # Per-node nonce LRU for register.
+        self._register_nonces: dict[str, dict[str, float]] = {}
+
+    def remember_id(self, node_id: str, msg_id: str) -> bool:
+        """Returns True if the id is fresh; False if it's a replay."""
+        lru = self._seen_ids.setdefault(node_id, collections.OrderedDict())
+        if msg_id in lru:
+            return False
+        lru[msg_id] = True
+        while len(lru) > REPLAY_LRU_PER_NODE:
+            lru.popitem(last=False)
+        return True
+
+    def remember_register_nonce(self, node_id: str, nonce: str) -> bool:
+        nset = self._register_nonces.setdefault(node_id, {})
+        now = _dt.datetime.now(_dt.timezone.utc).timestamp()
+        # Sweep old.
+        for k, t in list(nset.items()):
+            if now - t > REGISTER_NONCE_TTL:
+                nset.pop(k, None)
+        if nonce in nset:
+            return False
+        nset[nonce] = now
+        return True

