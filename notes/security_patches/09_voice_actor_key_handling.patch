+        # Prefer the ephemeral token (short-lived, scoped to one session).
+        # Fall back to the long-lived key only if no ephemeral was minted.
+        if not ephemeral_token and not api_key:
+            api_key = os.environ.get("OPENAI_API_KEY")
+        if not ephemeral_token and not api_key:
+            raise RuntimeError("RealtimeClient requires ephemeral_token or api_key")
+        self._token = ephemeral_token or api_key
