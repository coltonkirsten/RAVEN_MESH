# V-09: long-lived OPENAI_API_KEY only crosses the wire to mint an
# ephemeral session token; concurrent start_session is capped; dotenv
# never injects OPENAI_API_KEY into os.environ when the supervisor is
# active (so child processes don't inherit it).
# Files: nodes/voice_actor/voice_actor.py,
#        nodes/voice_actor/realtime_client.py
#
# DO NOT APPLY — proposal for review.

--- a/nodes/voice_actor/voice_actor.py
+++ b/nodes/voice_actor/voice_actor.py
@@ -47,32 +47,55 @@ import websockets
 from realtime_client import RealtimeClient


-def _load_dotenv(path: pathlib.Path) -> None:
-    if not path.exists():
-        return
-    for line in path.read_text().splitlines():
-        line = line.strip()
-        if not line or line.startswith("#"):
-            continue
-        if "=" not in line:
-            continue
-        k, _, v = line.partition("=")
-        os.environ.setdefault(k.strip(), v.strip().strip('"').strip("'"))
+# Sensitive vars must not leak to supervisor child processes via os.environ
+# — the supervisor calls start_new_session=True so the env propagates.
+_SENSITIVE_VARS = frozenset({"OPENAI_API_KEY", "OPENAI_ORG_ID"})
+
+
+def _load_dotenv(path: pathlib.Path, *, supervisor_active: bool) -> dict[str, str]:
+    """Returns a private dict for use within this process; only injects
+    non-sensitive vars into os.environ. When the supervisor is active,
+    sensitive vars are returned but NOT exported."""
+    if not path.exists():
+        return {}
+    private: dict[str, str] = {}
+    for line in path.read_text().splitlines():
+        line = line.strip()
+        if not line or line.startswith("#"):
+            continue
+        if "=" not in line:
+            continue
+        k, _, v = line.partition("=")
+        k = k.strip()
+        v = v.strip().strip('"').strip("'")
+        private[k] = v
+        if k in _SENSITIVE_VARS and supervisor_active:
+            continue  # do not export — child procs would inherit it
+        os.environ.setdefault(k, v)
+    return private
+
+
+_MAX_CONCURRENT_SESSIONS = 1
+_START_COOLDOWN_S = 5.0


 class VoiceActor:
     def __init__(self, ...):
         ...
+        self._active_sessions = 0
+        self._last_stop_at = 0.0
+        self._session_lock = asyncio.Lock()
@@ -571,15 +594,33 @@ class VoiceActor:
     async def start_session(self, payload: dict) -> dict:
+        async with self._session_lock:
+            now = time.monotonic()
+            if self._active_sessions >= _MAX_CONCURRENT_SESSIONS:
+                return {"ok": False, "error": "session_limit",
+                        "active": self._active_sessions}
+            if (now - self._last_stop_at) < _START_COOLDOWN_S:
+                return {"ok": False, "error": "cooldown",
+                        "retry_after_s": _START_COOLDOWN_S - (now - self._last_stop_at)}
+            self._active_sessions += 1
+        try:
             ...
+            # Mint an ephemeral session token. The long-lived key only
+            # ever sees this one HTTP call per session.
+            ephemeral = await self._mint_ephemeral_session_token(
+                model=payload.get("model", "gpt-4o-realtime-preview"),
+                voice=payload.get("voice", "alloy"),
+            )
+            self.client = RealtimeClient(ephemeral_token=ephemeral["client_secret"]["value"])
             ...
+        finally:
+            async with self._session_lock:
+                self._active_sessions -= 1
+                self._last_stop_at = time.monotonic()
+
+    async def _mint_ephemeral_session_token(self, *, model: str, voice: str) -> dict:
+        async with aiohttp.ClientSession() as s:
+            async with s.post(
+                "https://api.openai.com/v1/realtime/sessions",
+                headers={"Authorization": f"Bearer {self._openai_key}",
+                         "Content-Type": "application/json"},
+                json={"model": model, "voice": voice},
+            ) as r:
+                r.raise_for_status()
+                return await r.json()

