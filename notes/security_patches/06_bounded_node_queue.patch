# V-06: bound per-node delivery queues; convert queue saturation into
# a visible 503 + audit entry; evict the slow node on repeat saturation.
# File: core/core.py
#
# Default cap is 1024 envelopes per node. Tunable via MESH_NODE_QUEUE_MAX.
# Three consecutive QueueFulls trip an _close that forces re-register.
#
# DO NOT APPLY — proposal for review.

--- a/core/core.py
