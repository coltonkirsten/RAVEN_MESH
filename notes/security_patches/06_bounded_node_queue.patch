@@ -36,6 +36,9 @@ from jsonschema import ValidationError, validate as jsonschema_validate
 from core.supervisor import Supervisor, make_script_resolver


+NODE_QUEUE_MAX = int(os.environ.get("MESH_NODE_QUEUE_MAX", "1024"))
+NODE_QUEUE_STRIKES = 3
+
 ENVELOPE_TAIL_MAX = 200

@@ -200,12 +203,14 @@ async def handle_register(request: web.Request) -> web.Response:
     state: CoreState = request.app["state"]
     ...
-    queue: asyncio.Queue = asyncio.Queue()
+    queue: asyncio.Queue = asyncio.Queue(maxsize=NODE_QUEUE_MAX)
     session_id = uuid.uuid4().hex
     state.connections[node_id] = {
         "queue": queue,
         "session_id": session_id,
         "registered_at": now_iso(),
+        "strikes": 0,
