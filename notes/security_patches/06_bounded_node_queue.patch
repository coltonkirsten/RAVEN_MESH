     ...


+def _try_deliver(state: CoreState, to_node: str, conn: dict, env: dict) -> bool:
+    """Best-effort enqueue. Returns False on saturation; bumps strike
+    counter and forces a re-register after NODE_QUEUE_STRIKES."""
+    q: asyncio.Queue = conn["queue"]
+    try:
+        q.put_nowait({"type": "deliver", "data": env})
+    except asyncio.QueueFull:
+        conn["strikes"] = conn.get("strikes", 0) + 1
+        # Audit is async, but we're in a sync helper — schedule it.
+        asyncio.create_task(state.audit({
+            "event": "denied_queue_full",
+            "to": to_node,
+            "id": env.get("id"),
+            "strikes": conn["strikes"],
+        }))
+        if conn["strikes"] >= NODE_QUEUE_STRIKES:
+            try:
+                # _close is consumed by the streaming loop and ends the SSE.
+                q.put_nowait({"type": "_close", "data": {"reason": "queue_full_eviction"}})
+            except asyncio.QueueFull:
+                pass  # already saturated; consumer is gone for sure
+            state.connections.pop(to_node, None)
+        return False
+    conn["strikes"] = 0
+    return True
+
+
 async def handle_invoke(request: web.Request) -> web.Response:
