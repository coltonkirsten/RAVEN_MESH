{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "core.spawn",
  "description": "Input payload for core.spawn. Start a supervised process by node id.",
  "type": "object",
  "additionalProperties": false,
  "required": ["node_id"],
  "properties": {
    "node_id": {
      "type": "string",
      "minLength": 1,
      "description": "Manifest-declared node id to spawn."
    }
  }
}
