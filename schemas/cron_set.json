{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "cron_set",
  "type": "object",
  "properties": {
    "schedule": {"type": "string", "description": "Cron expression — 5-field (min hour dom mon dow) or 6-field with seconds first (sec min hour dom mon dow)"},
    "target_surface": {"type": "string"},
    "payload_template": {"type": "object"}
  },
  "required": ["schedule", "target_surface", "payload_template"],
  "additionalProperties": true
}
