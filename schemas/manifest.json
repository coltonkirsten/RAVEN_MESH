{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RAVEN Mesh Manifest",
  "description": "Top-level shape of a mesh manifest YAML (parsed to JSON).",
  "type": "object",
  "required": ["nodes"],
  "additionalProperties": true,
  "properties": {
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/definitions/node" }
    },
    "relationships": {
      "type": "array",
      "items": { "$ref": "#/definitions/relationship" }
    }
  },
  "definitions": {
    "node": {
      "type": "object",
      "required": ["id", "kind", "surfaces"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_-]+$",
          "description": "Node identifier. Letters, digits, underscore, hyphen. No dots, slashes, or whitespace."
        },
        "kind": {
          "type": "string",
          "enum": ["actor", "capability", "approval", "hybrid"]
        },
        "runtime": {
          "type": "string",
          "minLength": 1
        },
        "identity_secret": {
          "type": "string"
        },
        "metadata": {
          "type": "object"
        },
        "surfaces": {
          "type": "array",
          "items": { "$ref": "#/definitions/surface" }
        }
      }
    },
    "surface": {
      "type": "object",
      "required": ["name", "type", "schema"],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_-]+$"
        },
        "type": {
          "type": "string",
          "enum": ["inbox", "tool"]
        },
        "invocation_mode": {
          "type": "string",
          "enum": ["request_response", "fire_and_forget"]
        },
        "schema": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "relationship": {
      "type": "object",
      "required": ["from", "to"],
      "additionalProperties": true,
      "properties": {
        "from": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^.]+\\.[^.]+$",
          "description": "node_id.surface_name — must contain exactly one dot."
        }
      }
    }
  }
}
